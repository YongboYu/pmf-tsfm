# =============================================================================
# Environment variables for PMF-TSFM
# Copy to .env and fill in your values.  NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Project root (absolute path to the repo checkout)
# Used by Hydra: ${oc.env:PROJECT_ROOT,${hydra:runtime.cwd}}
# ---------------------------------------------------------------------------
PROJECT_ROOT=/absolute/path/to/pmf-tsfm

# ---------------------------------------------------------------------------
# Weights & Biases
# Get your key at https://wandb.ai/authorize
# ---------------------------------------------------------------------------
WANDB_API_KEY=your_wandb_api_key_here

# Optional: your W&B entity (username or team). Leave unset to use default.
# WANDB_ENTITY=your_username_or_team

# On HPC nodes without internet, set OFFLINE to cache runs locally.
# Sync later with: wandb sync <run-dir>
# WANDB_MODE=offline

# ---------------------------------------------------------------------------
# GPU / CUDA (Linux host)
# ---------------------------------------------------------------------------
CUDA_VISIBLE_DEVICES=0

# ---------------------------------------------------------------------------
# HuggingFace model cache (redirect away from ~/.cache on shared filesystems)
# ---------------------------------------------------------------------------
# HF_HOME=/path/to/shared/hf_cache

# ---------------------------------------------------------------------------
# Suppress tokeniser parallelism warnings from HuggingFace
# ---------------------------------------------------------------------------
TOKENIZERS_PARALLELISM=false

# ---------------------------------------------------------------------------
# TimesFM v1 source path (required for timesfm/1_0_200m)
#
# 1. Clone the repo:  git clone --depth 1 https://github.com/google-research/timesfm.git ~/timesfm-repo
# 2. Point here:      TIMESFM_V1_PATH=~/timesfm-repo/src
# 3. Install deps:    uv sync --extra timesfm_legacy
#
# Model weights (google/timesfm-1.0-200m-pytorch) are auto-downloaded from HuggingFace.
# TimesFM 2.5 (timesfm/2_5_200m) and 1.0 can coexist because each inference run
# is a separate process — no package version conflict.
# ---------------------------------------------------------------------------
TIMESFM_V1_PATH=~/timesfm-repo/src
