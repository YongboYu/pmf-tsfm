# =============================================================================
# Environment variables for PMF-TSFM
# Copy to .env and fill in your values.  NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Project root (absolute path to the repo checkout)
# Used by Hydra: ${oc.env:PROJECT_ROOT,${hydra:runtime.cwd}}
# ---------------------------------------------------------------------------
PROJECT_ROOT=/absolute/path/to/pmf-tsfm

# ---------------------------------------------------------------------------
# Weights & Biases
# Get your key at https://wandb.ai/authorize
# ---------------------------------------------------------------------------
WANDB_API_KEY=your_wandb_api_key_here

# Optional: team or username slug from https://wandb.ai/<entity>/... (required for team runs).
# WANDB_ENTITY=your_team_slug
#
# Optional: project name (must exist under that entity in the W&B UI, or you get HTTP 404 on upload).
# WANDB_PROJECT=pmf-tsfm

# On HPC nodes without internet, set OFFLINE to cache runs locally.
# Sync later with: wandb sync <run-dir>
# WANDB_MODE=offline

# ---------------------------------------------------------------------------
# GPU / CUDA (Linux host)
# ---------------------------------------------------------------------------
CUDA_VISIBLE_DEVICES=0

# ---------------------------------------------------------------------------
# HuggingFace model cache (redirect away from ~/.cache on shared filesystems)
# ---------------------------------------------------------------------------
# HF_HOME=/path/to/shared/hf_cache

# ---------------------------------------------------------------------------
# Suppress tokeniser parallelism warnings from HuggingFace
# ---------------------------------------------------------------------------
TOKENIZERS_PARALLELISM=false

# ---------------------------------------------------------------------------
# TimesFM v1 source path (required for timesfm/1_0_200m AND timesfm/2_0_500m)
#
# Both models use the legacy TimesFM API (TimesFm / TimesFmHparams / TimesFmCheckpoint).
# This API lives in the v1.x branch of the repo — NOT in master (which is v2/2.5 only).
#
# 1. Clone v1.2.6 (last v1 release):
#      git clone --depth 1 --branch v1.2.6 \
#          https://github.com/google-research/timesfm.git ~/timesfm-v1-repo
#
# 2. Point here:
#      TIMESFM_V1_PATH=~/timesfm-v1-repo/src
#
# 3. Install legacy deps (once):
#      uv sync --extra timesfm_legacy
#
# IMPORTANT: Do NOT clone master — it only exposes the TimesFM 2.5 API and will fail.
# Model weights are auto-downloaded from HuggingFace on first use.
# ---------------------------------------------------------------------------
TIMESFM_V1_PATH=~/timesfm-v1-repo/src
