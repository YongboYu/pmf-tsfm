# =============================================================================
# .env.hpc.example — HPC-specific environment overrides for VSC wICE.
# Copy to $PROJECT_ROOT/.env on the cluster (setup_vsc.sh does this).
# NEVER commit a filled-in .env to git.
# =============================================================================

# W&B credentials (get from https://wandb.ai/authorize)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=pmf-tsfm
WANDB_ENTITY=                        # leave empty to use default

# W&B mode: online (default) | offline (for nodes without internet, sync later)
# WANDB_MODE=offline

# TimesFM v1/v2 source (needed for timesfm/1_0_200m and timesfm/2_0_500m)
# Clone once to VSC_DATA (not SCRATCH — survives cleanup):
#   git clone --depth 1 --branch v1.2.6 \
#       https://github.com/google-research/timesfm.git $VSC_DATA/timesfm-v1-repo
TIMESFM_V1_PATH=${VSC_DATA}/timesfm-v1-repo/src

# HF cache — MUST point to SCRATCH to avoid filling VSC_DATA quota
HF_HOME=${VSC_SCRATCH}/.cache/huggingface
TORCH_HOME=${VSC_SCRATCH}/.cache/torch

# Optional Slurm override. Default in hpc_env.sh is gpu_h100 on wICE.
# Set this only if you intentionally want a different partition.
# SLURM_PARTITION=gpu_h100

# Optional run suffix to keep result variants side by side on VSC.
# Example:
#   HPC_RUN_SUFFIX=moirai-bf16
#   HPC_RUN_SUFFIX=moirai-tf32
# HPC_RUN_SUFFIX=

# Optional Moirai fine-tuning precision override for comparison runs.
# Leave unset for the default paper-aligned behavior.
# MOIRAI_TRAIN_PRECISION=bf16_amp
# MOIRAI_TRAIN_PRECISION=tf32

# Suppress tokenizer parallelism warnings
TOKENIZERS_PARALLELISM=false

# CUDA visibility (usually managed by Slurm gres; leave as-is)
# CUDA_VISIBLE_DEVICES=0
